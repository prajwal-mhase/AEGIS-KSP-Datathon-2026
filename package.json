{
  "name": "aegis-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AEGIS - Smart Unified Threat & Response Analytics for conversational crime intelligence.",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace shared && npm run build --workspace server && npm run build --workspace client",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.18.0",
    "npm": ">=10.0.0"
  }
}
